# Runtime
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/errorfinder

# LLM provider (Groq)
GROQ_API_KEY=
LLM_MODEL_REASONING=llama-3.3-70b-versatile
LLM_MODEL_FAST=llama-3.1-8b-instant
LLM_REQUEST_TIMEOUT_MS=45000
LLM_MAX_RETRIES=2

# Retrieval (Tavily)
TAVILY_API_KEY=
TAVILY_REQUEST_TIMEOUT_MS=20000

# Pipeline limits
MAX_VERIFICATION_ITERATIONS=2
MAX_CLAIMS_PER_RUN=30
MAX_EVIDENCE_PER_VERIFICATION=12
RETRIEVAL_RESULTS_STANDARD=8
RETRIEVAL_RESULTS_PROFESSIONAL=10
# Hard cap on Tavily calls per /verify (shared evidence pool across all claims).
RETRIEVAL_MAX_CALLS_PER_RUN=3
CLAIM_CONCURRENCY=4

# Optional: pin "today" for deterministic eval runs. ISO date (YYYY-MM-DD).
TODAY_DATE_OVERRIDE=
